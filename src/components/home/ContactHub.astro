---
import { site, waLink } from "@data/site";
import GoogleMap from "@components/shared/GoogleMap.astro";
const info = [
  { icon: "location_on", label: "Sede principal", value: site.address },
  { icon: "call", label: "Atención comercial", value: site.phoneDisplay },
];
---
<section id="contacto" class="bg-navy text-white py-16 md:py-20 border-t border-white/10">
  <div class="container-site flex flex-col md:flex-row gap-12 items-center">
    <div class="w-full md:w-3/5 space-y-6">
      <h2 class="text-3xl md:text-4xl font-black">¿Listo para asegurar o embellecer tu obra?</h2>
      <p class="text-lg text-sky/90">Nuestro equipo de asesores corporativos está listo para brindarte soporte técnico, cotizaciones rápidas y catálogos detallados.</p>
      <div class="space-y-4 py-2">
        {info.map((i) => (
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-blue mt-1">{i.icon}</span>
            <div>
              <p class="font-bold text-sky text-sm">{i.label}</p>
              <p class="text-white">{i.value}</p>
            </div>
          </div>
        ))}
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-blue mt-1">mail</span>
          <div>
            <p class="font-bold text-sky text-sm">Correos electrónicos</p>
            {site.emails.map((e) => <p class="text-white">{e}</p>)}
          </div>
        </div>
      </div>
      <a href={waLink("Hola, deseo iniciar una asesoría corporativa con D'ENERCON.")} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-3 px-8 py-4 bg-whatsapp text-white font-bold rounded-brand shadow-lg hover:-translate-y-1 transition-transform">
        <span class="material-symbols-outlined text-xl">forum</span>
        <span class="tracking-wider">INICIAR ASESORÍA CORPORATIVA POR WHATSAPP</span>
      </a>
    </div>
    <div class="w-full md:w-2/5 h-64 md:h-96">
      <GoogleMap />
    </div>
  </div>
</section>
