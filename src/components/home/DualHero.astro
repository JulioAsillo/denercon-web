---
import { Image } from "astro:assets";
import { waLink } from "@data/site.ts";
import heroFloors from "@assets/images/floors/home-hero-pisos.png";
import heroFire from "@assets/images/fire/puerta-cf-corredor-rojo.png";
---
<section class="relative h-[calc(100dvh-5rem)] min-h-[620px] w-full flex flex-col md:flex-row overflow-hidden">
  <!-- Izquierda: Pisos -->
  <div class="relative w-full md:w-1/2 h-1/2 md:h-full group overflow-hidden border-b md:border-b-0 md:border-r border-white/10">
    <Image src={heroFloors} alt="Interior lujoso con piso SPC roble claro y luz natural." widths={[768, 1280, 1920, 2560]} sizes="(max-width: 768px) 100vw, 50vw" class="absolute inset-0 transition-transform duration-700 group-hover:scale-105" style="width:100%;height:100%;object-fit:cover;object-position:center" />
    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-navy/90 via-navy/50 to-transparent"></div>
    <div class="absolute inset-0 flex flex-col justify-end md:justify-center p-6 md:p-16 z-10">
      <span class="text-sm font-bold text-sky mb-3 tracking-widest uppercase">Diseño y durabilidad</span>
      <h1 class="text-3xl md:text-5xl font-black text-white mb-6 max-w-lg leading-tight">Innovación y diseño para espacios que perduran</h1>
      <p class="text-lg text-sky/90 mb-8 max-w-md hidden md:block">Soluciones integrales en pisos SPC, laminados y revestimientos arquitectónicos para proyectos que demandan calidad sin comprometer la estética.</p>
      <a href="/pisos" class="w-fit px-8 py-3 bg-sky text-navy font-bold rounded-brand hover:bg-white transition-colors shadow-lg uppercase tracking-wide text-sm">Ver sistemas de acabados</a>
    </div>
  </div>

  <!-- Derecha: Cortafuego -->
  <div class="relative w-full md:w-1/2 h-1/2 md:h-full group overflow-hidden">
    <Image src={heroFire} alt="Corredor institucional con puerta cortafuego de acero roja." widths={[768, 1280, 1920, 2560]} sizes="(max-width: 768px) 100vw, 50vw" class="absolute inset-0 transition-transform duration-700 group-hover:scale-105" style="width:100%;height:100%;object-fit:cover;object-position:center" />
    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-l from-navy/90 via-navy/50 to-transparent"></div>
    <div class="absolute inset-0 flex flex-col justify-end md:justify-center items-start md:items-end p-6 md:p-16 text-left md:text-right z-10">
      <span class="text-sm font-bold text-fire mb-3 tracking-widest uppercase drop-shadow-[0_1px_3px_rgba(11,31,46,0.9)]">Seguridad certificada para edificaciones</span>
      <h1 class="text-3xl md:text-5xl font-black text-white mb-6 max-w-lg leading-tight">Seguridad certificada para proteger lo que importa</h1>
      <p class="text-lg text-sky/90 mb-8 max-w-md hidden md:block">Sistemas cortafuego certificados para edificaciones modernas, industriales y comerciales.</p>
      <a href="/cortafuego" class="w-fit px-8 py-3 bg-fire text-white font-bold rounded-brand hover:brightness-110 transition-all shadow-lg uppercase tracking-wide text-sm">Ver sistemas cortafuego</a>
    </div>
  </div>
</section>
