---
import { Image } from "astro:assets";
import type { Product } from "@data/products";
import WhatsAppButton from "@components/ui/WhatsAppButton.astro";

interface Props {
  product: Product;
  accent?: "blue" | "fire";
}
const { product, accent = "blue" } = Astro.props;
const iconColor = accent === "fire" ? "text-fire" : "text-blue";
const cardBg = accent === "fire" ? "bg-fire-soft border-fire/20" : "bg-white border-navy/10";
const badgeBg = accent === "fire" ? "bg-fire" : "bg-navy";

const colors = product.colors ?? [];
const hasCarousel = colors.length > 0;
---

{hasCarousel ? (
  <article
    class={`rounded-brand border ${cardBg} overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col sm:flex-row`}
    data-color-carousel
  >
    <!-- Media 3:4 -->
    <div class="relative w-full sm:w-[42%] lg:w-[44%] sm:max-w-[460px] shrink-0 p-3 md:p-4">
      <div class="relative aspect-[3/4] rounded-brand overflow-hidden bg-navy">
        {colors.map((c, i) => (
          <div class={`cc-slide absolute inset-0 transition-opacity duration-400 ${i === 0 ? "opacity-100" : "opacity-0"}`} data-label={c.label}>
            <Image
              src={c.src}
              alt={`${product.title} — ${c.label}`}
              widths={[440, 640, 900, 1280]}
              sizes="(max-width: 640px) 90vw, (max-width: 1536px) 44vw, 460px"
              loading={i === 0 ? "eager" : "lazy"}
              class="w-full h-full object-cover"
            />
          </div>
        ))}
        <span class="cc-label absolute left-2 bottom-2 z-10 text-white text-xs font-semibold px-2.5 py-1 rounded-full bg-navy/80 backdrop-blur-sm">
          {colors[0].label}
        </span>
        {colors.length > 1 && (
          <>
            <button type="button" class="cc-prev absolute left-1.5 top-1/2 -translate-y-1/2 z-10 w-8 h-8 grid place-items-center rounded-full bg-white/85 text-navy hover:bg-white" aria-label="Color anterior">
              <span class="material-symbols-outlined text-[20px]">chevron_left</span>
            </button>
            <button type="button" class="cc-next absolute right-1.5 top-1/2 -translate-y-1/2 z-10 w-8 h-8 grid place-items-center rounded-full bg-white/85 text-navy hover:bg-white" aria-label="Color siguiente">
              <span class="material-symbols-outlined text-[20px]">chevron_right</span>
            </button>
          </>
        )}
      </div>
    </div>

    <!-- Contenido -->
    <div class="p-6 flex-1 flex flex-col">
      {product.badge && (
        <span class={`self-start ${badgeBg} text-white text-xs font-bold px-2 py-1 rounded shadow mb-3`}>{product.badge}</span>
      )}
      <h3 class="text-xl font-bold text-navy mb-1">{product.title}</h3>
      {product.subtitle && <p class="text-sm text-blue font-medium mb-4">{product.subtitle}</p>}
      <ul class="space-y-2 mb-6 flex-1 text-sm text-navy/70">
        {product.features.map((f) => (
          <li class="flex items-start gap-2">
            <span class={`material-symbols-outlined text-[18px] ${iconColor}`}>{f.icon}</span>
            <span>{f.text}</span>
          </li>
        ))}
      </ul>
      {colors.length > 1 && (
        <div class="cc-dots flex gap-1.5 mb-5">
          {colors.map((c, i) => (
            <button type="button" class={`cc-dot w-2 h-2 rounded-full transition ${i === 0 ? "bg-blue scale-125" : "bg-navy/25"}`} data-index={i} aria-label={c.label}></button>
          ))}
        </div>
      )}
      <WhatsAppButton message={product.waMessage} label={product.ctaLabel} class="mt-auto" />
    </div>
  </article>
) : (
  <article class={`rounded-brand border ${cardBg} overflow-hidden flex flex-col shadow-sm hover:shadow-md transition-shadow group`}>
    <div class="relative h-56 overflow-hidden">
      <Image
        src={product.image}
        alt={product.alt}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 33vw"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
      {product.badge && (
        <span class={`absolute top-2 right-2 ${badgeBg} text-white text-xs font-bold px-2 py-1 rounded shadow`}>{product.badge}</span>
      )}
    </div>
    <div class="p-6 flex-1 flex flex-col">
      <h3 class="text-xl font-bold text-navy mb-1">{product.title}</h3>
      {product.subtitle && <p class="text-sm text-blue font-medium mb-4">{product.subtitle}</p>}
      <ul class="space-y-2 mb-8 flex-1 text-sm text-navy/70">
        {product.features.map((f) => (
          <li class="flex items-start gap-2">
            <span class={`material-symbols-outlined text-[18px] ${iconColor}`}>{f.icon}</span>
            <span>{f.text}</span>
          </li>
        ))}
      </ul>
      <WhatsAppButton message={product.waMessage} label={product.ctaLabel} full class="mt-auto" />
    </div>
  </article>
)}

<script>
  function initColorCarousels() {
    document.querySelectorAll<HTMLElement>("[data-color-carousel]").forEach((card) => {
      const slides = Array.from(card.querySelectorAll<HTMLElement>(".cc-slide"));
      const dots = Array.from(card.querySelectorAll<HTMLButtonElement>(".cc-dot"));
      const label = card.querySelector<HTMLElement>(".cc-label");
      if (slides.length === 0) return;
      let current = 0;
      const go = (i: number) => {
        current = (i + slides.length) % slides.length;
        slides.forEach((s, idx) => {
          s.classList.toggle("opacity-100", idx === current);
          s.classList.toggle("opacity-0", idx !== current);
        });
        dots.forEach((d, idx) => {
          d.classList.toggle("bg-blue", idx === current);
          d.classList.toggle("scale-125", idx === current);
          d.classList.toggle("bg-navy/25", idx !== current);
        });
        if (label) label.textContent = slides[current].dataset.label ?? "";
      };
      card.querySelector(".cc-prev")?.addEventListener("click", () => go(current - 1));
      card.querySelector(".cc-next")?.addEventListener("click", () => go(current + 1));
      dots.forEach((d) => d.addEventListener("click", () => go(Number(d.dataset.index ?? "0"))));
    });
  }
  initColorCarousels();
  document.addEventListener("astro:page-load", initColorCarousels);
</script>
