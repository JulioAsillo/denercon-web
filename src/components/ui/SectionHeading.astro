---
interface Props {
  title: string;
  accent?: "blue" | "fire";
  align?: "left" | "center";
}
const { title, accent = "blue", align = "left" } = Astro.props;
const bar = accent === "fire" ? "bg-fire" : "bg-blue";
const alignCls = align === "center" ? "text-center" : "text-left";
---
<div class={alignCls}>
  <h2 class="text-2xl md:text-3xl font-bold text-navy mb-3 border-l-4 pl-4 inline-block" style={`border-color: var(--color-${accent === 'fire' ? 'fire' : 'blue'})`}>
    {title}
  </h2>
  <div class={`h-1 w-24 ${bar} rounded-full ${align === 'center' ? 'mx-auto' : ''}`}></div>
</div>
