---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export type Slide = {
  image: ImageMetadata;
  alt: string;
  /** Etiqueta visible sobre la imagen (color o caso de uso). */
  label?: string;
  /** Segunda línea opcional bajo la etiqueta. */
  caption?: string;
};

interface Props {
  slides: Slide[];
  /** 1 = una imagen a lo ancho · 3 = tres visibles en desktop, 1.2 en móvil. */
  perView?: 1 | 3;
  autoplay?: boolean;
  /** Milisegundos entre avances de autoplay. */
  interval?: number;
  /** Clase Tailwind de proporción. Ej: "aspect-[4/3]", "aspect-video". */
  ratio?: string;
  widths?: number[];
  sizes?: string;
  accent?: "blue" | "fire" | "light";
  /** Tamaño de la etiqueta. */
  labelSize?: "sm" | "lg";
  class?: string;
}

const {
  slides,
  perView = 1,
  autoplay = false,
  interval = 4500,
  ratio = "aspect-[4/3]",
  widths = [480, 800, 1200],
  sizes = "(max-width: 768px) 100vw, 33vw",
  accent = "blue",
  labelSize = "sm",
  class: className = "",
} = Astro.props;

const accentBg =
  accent === "fire" ? "bg-fire" : accent === "light" ? "bg-white/90" : "bg-navy";
const accentText = accent === "light" ? "text-navy" : "text-white";
const slideWidth = perView === 3 ? "w-[85%] sm:w-[60%] lg:w-1/3" : "w-full";
---

{
  slides.length > 0 && (
    <div
      class={`dc-carousel relative group/car ${className}`}
      data-carousel
      data-autoplay={autoplay ? "true" : "false"}
      data-interval={String(interval)}
      data-count={String(slides.length)}
    >
      {/* Pista */}
      <div
        class="dc-track flex overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar"
        data-track
      >
        {slides.map((s, i) => (
          <div
            class={`dc-slide relative shrink-0 snap-start ${slideWidth} ${ratio} overflow-hidden`}
            data-slide
            data-index={i}
          >
            <Image
              src={s.image}
              alt={s.alt}
              widths={widths}
              sizes={sizes}
              loading={i === 0 ? "eager" : "lazy"}
              class="w-full h-full object-cover"
            />
            {s.label && (
              <div class="absolute inset-x-0 bottom-0 pointer-events-none">
                <div class="h-24 bg-gradient-to-t from-navy/85 to-transparent" />
                <div class="absolute bottom-0 inset-x-0 p-4">
                  <span
                    class={`inline-block ${accentBg} ${accentText} font-bold rounded-brand shadow ${
                      labelSize === "lg"
                        ? "text-sm md:text-base px-4 py-2 tracking-wide uppercase"
                        : "text-xs px-3 py-1.5"
                    }`}
                  >
                    {s.label}
                  </span>
                  {s.caption && (
                    <p class="text-white/85 text-xs mt-2 drop-shadow">{s.caption}</p>
                  )}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Flechas — solo si hay más slides que los visibles */}
      {slides.length > perView && (
        <>
          <button
            type="button"
            data-prev
            aria-label="Imagen anterior"
            class="dc-arrow left-3"
          >
            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
          </button>
          <button
            type="button"
            data-next
            aria-label="Imagen siguiente"
            class="dc-arrow right-3"
          >
            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
          </button>
        </>
      )}

      {/* Puntos */}
      {slides.length > perView && (
        <div
          class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 z-10"
          data-dots
        >
          {slides.map((_, i) => (
            <button
              type="button"
              data-dot
              data-index={i}
              aria-label={`Ir a la imagen ${i + 1}`}
              class="w-1.5 h-1.5 rounded-full bg-white/50 ring-1 ring-navy/20 transition-all"
            />
          ))}
        </div>
      )}
    </div>
  )
}

<script>
  // Un solo script para TODAS las instancias del carrusel del sitio.
  // Astro lo deduplica automáticamente aunque el componente se use N veces.
  function initCarousels() {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
      if (root.dataset.ready === "1") return;
      root.dataset.ready = "1";

      const track = root.querySelector<HTMLElement>("[data-track]");
      if (!track) return;

      const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
      const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
      const prev = root.querySelector<HTMLButtonElement>("[data-prev]");
      const next = root.querySelector<HTMLButtonElement>("[data-next]");
      if (slides.length === 0) return;

      let current = 0;

      const paint = () => {
        dots.forEach((d, i) => {
          const on = i === current;
          d.classList.toggle("bg-white", on);
          d.classList.toggle("w-4", on);
          d.classList.toggle("bg-white/50", !on);
          d.classList.toggle("w-1.5", !on);
        });
      };

      const goTo = (i: number) => {
        current = (i + slides.length) % slides.length;
        track.scrollTo({ left: slides[current].offsetLeft - track.offsetLeft });
        paint();
      };

      prev?.addEventListener("click", () => goTo(current - 1));
      next?.addEventListener("click", () => goTo(current + 1));
      dots.forEach((d) =>
        d.addEventListener("click", () => goTo(Number(d.dataset.index ?? 0))),
      );

      // Sincroniza los puntos cuando el usuario arrastra / hace swipe
      let raf = 0;
      track.addEventListener("scroll", () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const center = track.scrollLeft + track.clientWidth / 2;
          let best = 0;
          let bestDist = Infinity;
          slides.forEach((s, i) => {
            const c = s.offsetLeft - track.offsetLeft + s.clientWidth / 2;
            const d = Math.abs(c - center);
            if (d < bestDist) {
              bestDist = d;
              best = i;
            }
          });
          current = best;
          paint();
        });
      });

      paint();

      // ── Autoplay ──────────────────────────────────────────────────
      if (root.dataset.autoplay !== "true" || reduce) return;

      const delay = Number(root.dataset.interval ?? 4500);
      let timer: ReturnType<typeof setInterval> | null = null;
      const play = () => {
        if (timer) return;
        timer = setInterval(() => goTo(current + 1), delay);
      };
      const stop = () => {
        if (!timer) return;
        clearInterval(timer);
        timer = null;
      };

      root.addEventListener("mouseenter", stop);
      root.addEventListener("mouseleave", play);
      root.addEventListener("focusin", stop);
      root.addEventListener("focusout", play);
      track.addEventListener("pointerdown", stop);
      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : play(),
      );

      // Solo corre cuando el carrusel está en pantalla
      new IntersectionObserver(
        (entries) => entries.forEach((e) => (e.isIntersecting ? play() : stop())),
        { threshold: 0.3 },
      ).observe(root);
    });
  }

  initCarousels();
  document.addEventListener("astro:page-load", initCarousels);
</script>
