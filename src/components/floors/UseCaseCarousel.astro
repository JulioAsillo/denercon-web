---
/**
 * UseCaseCarousel.astro — Casos de uso (/pisos)
 * -----------------------------------------------------------------------------
 * Banda FULL-BLEED (todo el ancho de pantalla, hasta 4K). Una imagen a la vez
 * con crossfade; la etiqueta "Uso en …" aparece con un fade-up en cada cambio.
 *
 * Imágenes en:  src/assets/images/floors/casos-uso/
 *   caso-<ambiente>-NN.(png|jpg)  2400x1350 (16:9)
 *   caso-terraza-01.png -> "Uso en terraza"
 * Carpeta vacía → la sección no se renderiza (no rompe el build).
 */
import { Image } from "astro:assets";
import SectionHeading from "@components/ui/SectionHeading.astro";

type CaseModule = { default: ImageMetadata };
const modules = import.meta.glob<CaseModule>(
  "/src/assets/images/floors/casos-uso/*.{png,jpg,jpeg,webp}",
  { eager: true }
);

function labelFromPath(path: string): string {
  const file = path.split("/").pop()!.replace(/\.[^.]+$/, "");
  const amb = file
    .replace(/^caso-/, "")
    .replace(/[-_]?\d+$/, "")
    .replace(/[-_]/g, " ")
    .trim();
  return `Uso en ${amb}`;
}

const cases = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => ({ src: mod.default, label: labelFromPath(path) }));
---

{cases.length > 0 && (
  <section class="bg-navy">
    <div class="container-site pt-14 md:pt-20 pb-6 md:pb-8">
      <SectionHeading title="Casos de uso" accent="blue" />
    </div>

    <div
      class="uc relative w-full overflow-hidden h-[58vh] min-h-[420px] max-h-[900px]"
      data-uc
    >
      {cases.map((c, i) => (
        <figure class={`uc-slide absolute inset-0 ${i === 0 ? "is-active" : ""}`}>
          <Image
            src={c.src}
            alt={c.label}
            widths={[1280, 1920, 2560, 3840]}
            sizes="100vw"
            loading={i === 0 ? "eager" : "lazy"}
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy/85 via-navy/25 to-transparent"></div>
          <figcaption class="uc-label absolute left-6 md:left-16 2xl:left-28 bottom-8 md:bottom-14 text-white font-black uppercase tracking-wide text-2xl md:text-4xl 2xl:text-5xl drop-shadow-lg">
            {c.label}
          </figcaption>
        </figure>
      ))}

      {cases.length > 1 && (
        <>
          <button type="button" class="uc-arrow uc-prev" aria-label="Anterior">
            <span class="material-symbols-outlined">chevron_left</span>
          </button>
          <button type="button" class="uc-arrow uc-next" aria-label="Siguiente">
            <span class="material-symbols-outlined">chevron_right</span>
          </button>
          <div class="uc-dots absolute left-1/2 -translate-x-1/2 bottom-5 flex gap-2 z-10"></div>
        </>
      )}
    </div>
  </section>
)}

<style>
  .uc-slide { opacity: 0; transition: opacity 0.8s ease; pointer-events: none; }
  .uc-slide.is-active { opacity: 1; pointer-events: auto; }

  /* La etiqueta entra con fade-up cada vez que su slide se activa */
  .uc-label { opacity: 0; transform: translateY(14px); }
  .uc-slide.is-active .uc-label {
    animation: ucLabelIn 0.7s 0.25s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  @keyframes ucLabelIn { to { opacity: 1; transform: translateY(0); } }

  .uc-arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 10;
    width: 48px; height: 48px; display: grid; place-items: center;
    border: none; border-radius: 999px; cursor: pointer;
    color: var(--color-navy); background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.25); transition: background 0.2s ease;
  }
  .uc-arrow:hover { background: #fff; }
  .uc-prev { left: 16px; }
  .uc-next { right: 16px; }
  @media (min-width: 1536px) {
    .uc-arrow { width: 60px; height: 60px; }
    .uc-prev { left: 32px; }
    .uc-next { right: 32px; }
  }

  .uc-dot {
    width: 9px; height: 9px; border: none; border-radius: 999px; padding: 0;
    background: rgba(255, 255, 255, 0.45); cursor: pointer; transition: all 0.2s ease;
  }
  .uc-dot.is-active { background: #fff; width: 26px; }
</style>

<script>
  function initUseCase() {
    document.querySelectorAll<HTMLElement>("[data-uc]").forEach((root) => {
      const slides = Array.from(root.querySelectorAll<HTMLElement>(".uc-slide"));
      if (slides.length === 0) return;
      const dotsWrap = root.querySelector<HTMLElement>(".uc-dots");
      let index = 0;

      // construir puntos
      const dots: HTMLButtonElement[] = [];
      if (dotsWrap) {
        slides.forEach((_, i) => {
          const d = document.createElement("button");
          d.className = "uc-dot" + (i === 0 ? " is-active" : "");
          d.setAttribute("aria-label", `Ir al caso ${i + 1}`);
          d.addEventListener("click", () => go(i));
          dotsWrap.appendChild(d);
          dots.push(d);
        });
      }

      const go = (i: number) => {
        index = (i + slides.length) % slides.length;
        slides.forEach((s, idx) => s.classList.toggle("is-active", idx === index));
        dots.forEach((d, idx) => d.classList.toggle("is-active", idx === index));
      };

      root.querySelector(".uc-next")?.addEventListener("click", () => go(index + 1));
      root.querySelector(".uc-prev")?.addEventListener("click", () => go(index - 1));

      let timer = window.setInterval(() => go(index + 1), 5000);
      const pause = () => clearInterval(timer);
      const resume = () => { timer = window.setInterval(() => go(index + 1), 5000); };
      root.addEventListener("mouseenter", pause);
      root.addEventListener("mouseleave", resume);
    });
  }
  initUseCase();
  document.addEventListener("astro:page-load", initUseCase);
</script>
