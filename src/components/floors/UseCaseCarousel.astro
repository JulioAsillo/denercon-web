---
import Carousel from "@components/ui/Carousel.astro";
import { useCases } from "@data/usecases";

// Si aún no hay imágenes de casos de uso, la sección no se renderiza.
const slides = useCases.map((u) => ({
  image: u.image,
  alt: u.alt,
  label: u.label,
  caption: u.caption,
}));
---

{
  slides.length > 0 && (
    <section class="w-full bg-navy py-12 md:py-16 overflow-hidden">
      <div class="container-site mb-8">
        <span class="text-sky/60 text-xs tracking-[0.2em] uppercase font-semibold">
          Casos de uso
        </span>
        <h2 class="text-2xl md:text-3xl font-bold text-white mt-2">
          Nuestras superficies en proyectos reales
        </h2>
      </div>

      <Carousel
        slides={slides}
        perView={3}
        autoplay={true}
        interval={5000}
        ratio="aspect-video"
        widths={[600, 1000, 1600, 2400]}
        sizes="(max-width: 640px) 85vw, (max-width: 1024px) 60vw, 33vw"
        accent="light"
        labelSize="lg"
        class="w-full px-4 md:px-16"
      />
    </section>
  )
}
