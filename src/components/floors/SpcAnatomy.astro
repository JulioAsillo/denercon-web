---
import fs from "node:fs";

// ════════════════════════════════════════════════════════════════════
//  ANIMACIÓN "Anatomía de un piso ígneo"  (After Effects → video)
// ════════════════════════════════════════════════════════════════════
//  Assets esperados en public/anim/ :
//      spc-anatomy.mp4          ← principal, compatible con todo
//      spc-anatomy.webm         ← opcional, más liviano (VP9)
//      spc-anatomy-poster.jpg   ← opcional, evita el flash de carga
//
//  Si el .mp4 NO existe, el componente cae automáticamente a la pila
//  isométrica CSS de siempre. No hay que tocar código para activarlo.
//
//  Origen: secuencia PNG 1200x1600 @ 30 fps, 360 frames = 12.000 s,
//  compuesta sobre #0B1F2E al codificar (el alpha venía en los PNG).
// ════════════════════════════════════════════════════════════════════
const publicFile = (f: string) =>
  fs.existsSync(new URL(`../../../public/anim/${f}`, import.meta.url));

const hasVideo = publicFile("spc-anatomy.mp4");
const hasWebm = publicFile("spc-anatomy.webm");
const hasPoster = publicFile("spc-anatomy-poster.jpg");

// Beats de la animación (segundos). Cada capa queda activa hasta que
// arranca la siguiente, así el resaltado nunca se apaga entre medias.
//   0.0 – 1.0  despliegue de las 5 láminas, sin resaltado
const BEATS = [
  { n: 1, start: 1.0 },
  { n: 2, start: 2.0 },
  { n: 3, start: 4.0 },
  { n: 4, start: 6.0 },
  { n: 5, start: 9.0 },
];

const layers = [
  {
    n: 1,
    title: "Filtro UV superior",
    desc: "Protege el diseño contra la decoloración por luz solar, garantizando colores vivos por años.",
  },
  {
    n: 2,
    title: "Capa de desgaste transparente",
    desc: "Escudo de alta resistencia a la abrasión y a la rayadura, incluso en alto tránsito comercial.",
  },
  {
    n: 3,
    title: "Película decorativa HD",
    desc: "Texturas mate en alta definición que replican la madera natural de forma hiperrealista.",
  },
  {
    n: 4,
    title: "Núcleo rígido SPC",
    desc: "Compuesto de 40% polvo de piedra y polímeros. 100% impermeable e ígneo: el piso SPC no se quema.",
  },
  {
    n: 5,
    title: "Aislante acústico integrado",
    desc: "Base que absorbe el sonido de impacto y facilita la instalación sobre contrapiso.",
  },
];
---

<section class="w-full bg-white border-y border-navy/10">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-2 group spc-perspective">
      <!-- Izquierda: textos interactivos -->
      <div class="px-6 py-14 sm:px-10 lg:px-16 xl:px-24 lg:py-24 flex flex-col justify-center relative z-10 order-2 lg:order-1">
        <div class="w-full max-w-2xl lg:ml-auto">
        <span class="text-blue text-sm font-bold tracking-widest uppercase mb-3">
          Ingeniería de superficie
        </span>
        <h2 class="text-4xl md:text-5xl font-black text-navy mb-4 leading-[1.05]">
          Anatomía de un<br />piso ígneo
        </h2>
        <p class="text-navy/60 mb-10 max-w-md">
          No se quema. No se raya. Cinco capas trabajando juntas para resistir lo que
          el proyecto le exija.
        </p>

        <div class="space-y-3 relative" data-spc-triggers>
          {
            layers.map((l) => (
              <div
                class={`spc-trigger-${l.n} p-4 rounded-xl hover:bg-surface transition-colors cursor-pointer border-l-4 border-transparent hover:border-blue`}
                data-spc-trigger={`capa-${l.n}`}
                role="button"
                tabindex="0"
              >
                <h4 class="font-bold text-lg text-navy">
                  {l.n}. {l.title}
                </h4>
                <p class="text-sm text-navy/60 mt-1">{l.desc}</p>
              </div>
            ))
          }
        </div>
        </div>
      </div>

      <!-- Derecha: video de la animación, o pila isométrica CSS -->
      <div
        class={`order-1 lg:order-2 h-[62svh] min-h-[380px] max-h-[560px] lg:h-auto lg:max-h-none lg:min-h-[760px] flex items-center justify-center relative overflow-hidden spc-visual transition-colors duration-500 ${hasVideo ? "" : "bg-navy group-hover:bg-navy-90"}`}
        style={hasVideo ? "background-color:#0B1F2E" : undefined}
      >
        <div
          class="absolute bottom-6 right-6 text-white/40 text-xs tracking-widest uppercase flex items-center gap-2 z-10 pointer-events-none"
        >
          <span class="material-symbols-outlined text-base animate-bounce">touch_app</span>
          {hasVideo ? "Haz clic en una capa" : "Pasa el cursor"}
        </div>

        {
          hasVideo ? (
            <video
              class="w-full h-full object-contain p-6 lg:p-10"
              data-spc-video
              data-beats={JSON.stringify(BEATS)}
              muted
              loop
              playsinline
              preload="metadata"
              aria-label="Animación de las cinco capas de un piso SPC"
              poster={hasPoster ? "/anim/spc-anatomy-poster.jpg" : undefined}
            >
              {hasWebm && <source src="/anim/spc-anatomy.webm" type="video/webm" />}
              <source src="/anim/spc-anatomy.mp4" type="video/mp4" />
            </video>
          ) : (
            <div class="relative w-72 h-72 spc-stack">
              <div class="spc-layer spc-layer-1 absolute inset-0 bg-sky/40 border border-sky rounded-sm backdrop-blur-sm flex items-center justify-center">
                <span class="text-navy/60 font-bold text-xs -rotate-45">1. UV</span>
              </div>
              <div class="spc-layer spc-layer-2 absolute inset-0 bg-white/30 border border-white/50 rounded-sm backdrop-blur-md flex items-center justify-center">
                <span class="text-navy/50 font-bold text-xs -rotate-45">2. WEAR</span>
              </div>
              <div class="spc-layer spc-layer-3 absolute inset-0 bg-blue border border-blue-70 rounded-sm flex items-center justify-center overflow-hidden">
                <div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(45deg,transparent,transparent_10px,#000_10px,#000_11px)]" />
                <span class="text-white font-bold text-xs -rotate-45 relative z-10">
                  3. DECOR
                </span>
              </div>
              <div class="spc-layer spc-layer-4 absolute inset-0 bg-sky/70 border-2 border-sky rounded-sm flex items-center justify-center">
                <span class="text-navy font-black text-lg -rotate-45">4. SPC CORE</span>
              </div>
              <div class="spc-layer spc-layer-5 absolute inset-0 bg-navy-90 border border-navy rounded-sm flex items-center justify-center">
                <span class="text-sky/50 font-bold text-xs -rotate-45">5. PAD</span>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Sincroniza los textos de la izquierda con el video de la derecha.
  // Si no hay video renderizado (fallback CSS), no hace nada.
  type Beat = { n: number; start: number };

  function initSpcVideo() {
    const video = document.querySelector<HTMLVideoElement>("[data-spc-video]");
    if (!video || video.dataset.ready === "1") return;
    video.dataset.ready = "1";

    const beats: Beat[] = JSON.parse(video.dataset.beats ?? "[]");
    const triggers = Array.from(
      document.querySelectorAll<HTMLElement>("[data-spc-trigger]"),
    );
    if (beats.length === 0 || triggers.length === 0) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ── Resaltado del texto ──────────────────────────────────────
    let active = -1;
    const paint = (n: number) => {
      if (n === active) return;
      active = n;
      triggers.forEach((t) => {
        const mine = Number(t.dataset.spcTrigger?.replace("capa-", "") ?? "0");
        const on = mine === n;
        t.classList.toggle("border-blue", on);
        t.classList.toggle("border-transparent", !on);
        t.classList.toggle("bg-surface", on);
        t.setAttribute("aria-current", on ? "true" : "false");
      });
    };

    // Capa correspondiente a un instante dado (-1 = despliegue inicial)
    const beatAt = (t: number) => {
      let n = -1;
      for (const b of beats) if (t >= b.start) n = b.n;
      return n;
    };

    video.addEventListener("timeupdate", () => paint(beatAt(video.currentTime)));

    // ── Clic / teclado: salta al beat y reanuda el loop ──────────
    triggers.forEach((t) => {
      const n = Number(t.dataset.spcTrigger?.replace("capa-", "") ?? "0");
      const beat = beats.find((b) => b.n === n);
      if (!beat) return;

      t.setAttribute("aria-label", `Ver capa ${n} en la animación`);
      const jump = () => {
        // +0.05 s para caer dentro del beat, no justo en el borde
        video.currentTime = beat.start + 0.05;
        paint(n);
        if (!reduce) video.play().catch(() => {});
      };
      t.addEventListener("click", jump);
      t.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          jump();
        }
      });
    });

    // ── Reproducción solo en pantalla ────────────────────────────
    if (reduce) {
      // Sin autoplay: se muestra el primer frame y los clics siguen sirviendo
      video.pause();
      return;
    }

    new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          if (e.isIntersecting) video.play().catch(() => {});
          else video.pause();
        }),
      { threshold: 0.25 },
    ).observe(video);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) video.pause();
    });
  }

  initSpcVideo();
  document.addEventListener("astro:page-load", initSpcVideo);
</script>
