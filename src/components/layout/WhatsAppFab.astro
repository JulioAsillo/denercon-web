---
import { waLink } from "@data/site";
---
<a
  href={waLink("Hola, deseo conversar con un asesor corporativo de D'ENERCON.")}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-8 right-8 z-50 rounded-full p-4 flex items-center gap-2 bg-whatsapp text-white font-bold shadow-xl shadow-whatsapp/20 hover:scale-105 transition-transform animate-bounce-subtle group"
  aria-label="Cotizar por WhatsApp"
>
  <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">chat</span>
  <span class="hidden group-hover:inline-block whitespace-nowrap pr-2">Cotizar ahora</span>
</a>
