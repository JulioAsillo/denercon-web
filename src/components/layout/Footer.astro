---
import { site } from "@data/site";
import { certifications } from "@data/certifications";
const year = new Date().getFullYear();
const links = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/pisos", label: "Pisos y Revestimientos" },
  { href: "/cortafuego", label: "Seguridad Cortafuego" },
];
---
<footer class="bg-navy w-full py-16 border-t border-white/10 text-white">
  <div class="container-site grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="space-y-4">
      <!-- Logo con fondo navy (versión clara sobre oscuro) -->
      <img src="/brand/denercon-logo-fondo.png" alt="D'ENERCON" class="h-12 w-auto" width="1754" height="1241" />
      <p class="text-sm text-sky/80 max-w-xs">
        Soluciones integrales en revestimientos y seguridad industrial para proyectos corporativos.
      </p>
      <p class="text-xs text-sky/50">© {year} {site.brand}. Todos los derechos reservados.</p>
    </div>

    <div class="flex flex-col gap-2">
      <h3 class="font-bold text-white mb-2 uppercase tracking-wider text-sm">Navegación</h3>
      {links.map((l) => (
        <a href={l.href} class="text-sky/80 hover:text-white transition-colors text-sm">{l.label}</a>
      ))}
    </div>

    <div class="flex flex-col gap-2">
      <h3 class="font-bold text-white mb-2 uppercase tracking-wider text-sm">Contacto</h3>
      <span class="text-sky/80 text-sm">{site.address}</span>
      <span class="text-sky/80 text-sm">{site.phoneDisplay}</span>
      {site.emails.map((e) => (
        <a href={`mailto:${e}`} class="text-sky/80 hover:text-white transition-colors text-sm">{e}</a>
      ))}
      <div class="flex flex-wrap gap-3 items-center mt-4 opacity-70">
        {certifications.slice(0, 4).map((c) => (
          <span class="text-xs border border-white/30 rounded px-2 py-1">{c}</span>
        ))}
      </div>
    </div>
  </div>
</footer>
