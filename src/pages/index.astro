---
import BaseLayout from "@layouts/BaseLayout.astro";
import DualHero from "@components/home/DualHero.astro";
import TrustRibbon from "@components/ui/TrustRibbon.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import ProductCard from "@components/ui/ProductCard.astro";
import ContactHub from "@components/home/ContactHub.astro";
import { floorProducts, fireProducts } from "@data/products";
---
<BaseLayout active="inicio">
  <!-- El hero ocupa toda la altura, sin el padding-top del main -->
  <div class="-mt-20">
    <DualHero />
  </div>
  <TrustRibbon />

  <section class="py-16 md:py-20 bg-surface">
    <div class="container-site space-y-20">
      <div>
        <SectionHeading title="Soluciones de tránsito pesado y revestimiento decorativo" accent="blue" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
          {floorProducts.map((p) => <ProductCard product={p} accent="blue" />)}
        </div>
      </div>

      <div class="h-px w-full bg-navy/10"></div>

      <div>
        <SectionHeading title="Infraestructura de seguridad pasiva para proyectos de edificación" accent="fire" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
          {fireProducts.map((p) => <ProductCard product={p} accent="fire" />)}
        </div>
      </div>
    </div>
  </section>

  <ContactHub />
</BaseLayout>
