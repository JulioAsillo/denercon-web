---
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import ProductCard from "@components/ui/ProductCard.astro";
import SpcAnatomy from "@components/floors/SpcAnatomy.astro";
import UseCaseCarousel from "@components/floors/UseCaseCarousel.astro";
import { floorProducts } from "@data/products";

// HERO FULL-WIDTH — sobrescribe este archivo con el master 3840 x 1600 (12:5).
// Toma AMPLIA, tono OSCURO / AMADERADO (pedido del cliente).
// Punto focal en el tercio central horizontal: en móvil el recorte deja solo esa franja.
import heroFondo from "@assets/images/floors/pisos-hero-fondo.png";
---
<BaseLayout title="Pisos y Revestimientos — D'ENERCON" active="pisos">

  <!-- ══ HERO: imagen de fondo a todo el ancho + texto encima ══ -->
  <header class="relative w-full min-h-[540px] md:min-h-[680px] flex items-end overflow-hidden -mt-20">
    <Image
      src={heroFondo}
      alt="Ambiente interior de alta gama con piso SPC en tono amaderado."
      widths={[768, 1280, 1920, 2560, 3840]}
      sizes="100vw"
      loading="eager"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <!-- Velo oscuro: garantiza contraste AA del texto sobre cualquier foto -->
    <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/70 to-navy/30"></div>

    <div class="relative z-10 container-site pb-16 md:pb-24 pt-32">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-[1.02] max-w-4xl">
        Superficies premium para espacios excepcionales
      </h1>
      <p class="text-lg md:text-xl text-sky/90 max-w-2xl mt-6">
        Pisos SPC y revestimientos diseñados para brindar estética, resistencia y valor
        agregado a proyectos residenciales, comerciales y corporativos.
      </p>
    </div>
  </header>

  <!-- ══ Carrusel full-width de casos de uso ══ -->
  <UseCaseCarousel />

  <!-- ══ Catálogo ══ -->
  <section class="bg-white py-16 md:py-20">
    <div class="container-site">
      <SectionHeading title="Catálogo de productos" accent="blue" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10">
        {floorProducts.map((p) => <ProductCard product={p} accent="blue" />)}
      </div>
    </div>
  </section>

  <SpcAnatomy />
</BaseLayout>
