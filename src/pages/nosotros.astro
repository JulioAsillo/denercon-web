---
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import { waLink } from "@data/site";
import heroShowroom from "@assets/images/corporate/nosotros-hero-showroom.png";
import areaReunion from "@assets/images/corporate/nosotros-area-reunion.png";
---
<BaseLayout title="Nosotros — D'ENERCON" active="nosotros">
  <!-- Hero -->
  <section class="relative w-full h-[520px] flex items-center justify-center overflow-hidden -mt-20 pt-20">
    <Image src={heroShowroom} alt="Centro logístico y showroom corporativo de D'ENERCON." widths={[1280, 1920, 2560, 3840]} sizes="100vw" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-navy/75"></div>
    <div class="relative z-10 text-center container-site">
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4">D'ENERCON</h1>
      <p class="text-lg text-sky/90 max-w-2xl mx-auto">Excelencia y precisión en soluciones industriales y arquitectónicas.</p>
    </div>
  </section>

  <!-- Cuerpo -->
  <section class="py-16 md:py-20 container-site">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div>
          <h2 class="text-3xl font-bold text-navy mb-2">¿Quiénes son D'ENERCON?</h2>
          <div class="w-16 h-1 bg-blue rounded-full"></div>
        </div>
        <div class="space-y-4 text-lg text-navy/80">
          <p>
            D'ENERCON es una marca integradora de soluciones para el sector construcción. Su propuesta de valor
            fusiona la <strong class="text-navy">estética y funcionalidad</strong> de los acabados arquitectónicos
            con la máxima rigurosidad técnica de los sistemas de protección contra incendios.
          </p>
          <p>
            Operamos siempre bajo estrictos estándares de <strong class="text-navy">calidad internacional y
            transparencia corporativa</strong>, garantizando que cada producto cumpla con las normativas más
            exigentes para arquitectos, desarrolladores y especialistas en seguridad industrial.
          </p>
        </div>
        <div class="pt-8 border-t border-navy/10">
          <p class="text-navy/70 mb-4">¿Busca asesoría especializada para su proyecto?</p>
          <a href={waLink("Hola, deseo conversar con un asesor corporativo de D'ENERCON.")} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 bg-whatsapp text-white font-bold px-8 py-4 rounded-full shadow-lg hover:scale-105 transition-transform">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">chat</span>
            Conversa con un asesor corporativo
          </a>
        </div>
      </div>
      <div class="relative w-full h-[500px] rounded-brand overflow-hidden border border-navy/10">
        <Image src={areaReunion} alt="Área de reunión corporativa premium de D'ENERCON." widths={[600, 1000, 1600]} sizes="(max-width: 768px) 100vw, 50vw" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>
</BaseLayout>
